# MEMRAG Environment Variables
# Copy this file to .env and fill in required values

# Core Configuration
ENVIRONMENT=development
WORKSPACE_ID=default-workspace

# PostgreSQL Configuration
POSTGRES_PASSWORD=postgres

# MinIO Configuration
MINIO_ROOT_PASSWORD=minioadmin

# Qdrant Configuration (optional - used if connecting to remote instance)
QDRANT_API_KEY=memrag-secret

# Redis Configuration (optional - used if connecting to remote instance)
REDIS_URL=redis://redis:6379

# Temporal Configuration (optional - used if connecting to remote instance)
TEMPORAL_HOST=temporal:7233

# Ollama Configuration
OLLAMA_HOST=http://ollama:11434
OLLAMA_DEVICE=cuda

# External API Tokens
GITHUB_TOKEN=
CONFLUENCE_BASE_URL=
SLACK_API_BASE_URL=

# AWS Configuration (for S3 archive store, AppConfig, Secrets Manager, and optional RDS IAM auth)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=memrag-archive
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_FORCE_PATH_STYLE=true
AWS_APP_CONFIG_APPLICATION_ID=
AWS_APP_CONFIG_ENVIRONMENT_ID=
AWS_APP_CONFIG_PROFILE_ID=
AWS_APP_CONFIG_POLL_INTERVAL_SECONDS=60
AWS_SECRETS_MANAGER_PREFIX=/memrag/development
AWS_SECRETS_MANAGER_ENDPOINT_URL=
AWS_RDS_REGION=us-east-1
AWS_RDS_IAM_ENABLED=false
AWS_RDS_SSL_MODE=require

# Application Configuration
WEIGHTS_CONFIG_SOURCE=env-file
WEIGHTS_FILE=.weights.json

# PII Configuration
PII_ENTITY_CATEGORIES=EMAIL,PHONE,PERSON_NAME,PAN,UPI_ID,DEMAT_ID,CREDIT_CARD,BANK_ACCOUNT,IP_ADDRESS,HEALTH_INFO,PASSWORD,SECRET
PII_EMAIL_ACTION=mask
PII_PHONE_ACTION=mask
PII_PERSON_NAME_ACTION=mask
PII_CREDIT_CARD_ACTION=redact
PII_BANK_ACCOUNT_ACTION=redact
PII_PASSWORD_ACTION=drop
PII_SECRET_ACTION=drop

# Logging Configuration
LOG_LEVEL=INFO

# Test Environment Overrides (used by docker-compose.test.yml)
# ENVIRONMENT=test
# GITHUB_API_BASE_URL=http://github-api-mock:8085
# CONFLUENCE_BASE_URL=http://confluence-api-mock:8084
