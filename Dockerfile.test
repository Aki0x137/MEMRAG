FROM python:3.11-slim

WORKDIR /app

# Install system dependencies and uv
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/ \
    && curl -LsSf https://astral.sh/uv/install.sh | sh

ENV PATH="/root/.local/bin:$PATH"

# Copy project files
COPY . .

# Install the full workspace so service tests can import all runtime deps
RUN uv sync --frozen --all-packages --all-extras

# Install pytest and asyncio plugin
RUN uv pip install pytest pytest-asyncio

# Run tests from the workspace venv by default
CMD ["/app/.venv/bin/pytest", "tests/", "services/memory-api/tests/", "services/knowledge-ingestion/tests/", "-v", "--tb=short"]
